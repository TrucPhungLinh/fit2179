          "outerRadius": {
            "value": 208
          },
          "fill": {
            "value": "#F8EFE3"
          },
          "opacity": {
            "value": 0.9
          }
        }
      }
    },
    {
      "type": "arc",
      "name": "arcs",
      "from": {
        "data": "active_data"
      },
      "encode": {
        "update": {
          "x": {
            "signal": "cx"
          },
          "y": {
            "signal": "cy"
          },
          "innerRadius": {
            "field": "arcInner"
          },
          "outerRadius": {
            "field": "arcOuter"
          },
          "startAngle": {
            "value": -1.5708
          },
          "endAngle": {
            "field": "arcEndAngle"
          },
          "fill": {
            "value": "#FFF8EF"
          },
          "opacity": {
            "value": 0.96
          },
          "stroke": {
            "value": "#7B4B2E"
          },
          "strokeWidth": {
            "value": 0.5
          },
          "cornerRadius": {
            "value": 5
          },
          "cursor": {
            "value": "pointer"
          },
          "tooltip": {
            "signal": "{'Rank': datum.rank, 'Country': datum.country, 'Value': datum.displayValue, 'Region': datum.region}"
          }
        },
        "hover": {
