            "value": 3.14159
          },
          "innerRadius": {
            "value": 210
          },
          "outerRadius": {
            "value": 228
          },
          "fill": {
            "value": "#8A5A3C"
          }
        }
      }
    },
    {
      "type": "arc",
      "encode": {
        "enter": {
          "x": {
