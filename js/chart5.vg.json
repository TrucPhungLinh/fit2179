{
  "$schema": "https://vega.github.io/schema/vega/v5.json",
  "width": 760,
  "height": 840,
  "padding": 20,
  "background": "#F5EFE6",
  "signals": [
    {
      "name": "activeTab",
      "value": "imports",
      "on": [
        {
          "events": {
            "type": "click",
            "markname": "tab_imports"
          },
          "update": "'imports'"
        },
        {
          "events": {
            "type": "click",
            "markname": "tab_imports_label"
          },
          "update": "'imports'"
        },
        {
          "events": {
            "type": "click",
            "markname": "tab_exports"
          },
          "update": "'exports'"
        },
        {
          "events": {
            "type": "click",
            "markname": "tab_exports_label"
          },
          "update": "'exports'"
        }
      ]
    },
    {
      "name": "cx",
      "value": 300
    },
    {
      "name": "cy",
      "value": 460
    }
  ],
  "data": [
    {
      "name": "imports_raw",
      "url": "https://raw.githubusercontent.com/TrucPhungLinh/fit2179new/refs/heads/main/coffee_australia_imports.csv",
      "format": {
        "type": "csv",
        "parse": {
          "tonnes_2024": "number"
        }
      },
      "transform": [
        {
          "type": "filter",
          "expr": "datum.country !== 'Other'"
        },
        {
          "type": "collect",
          "sort": {
            "field": "tonnes_2024",
            "order": "descending"
          }
        },
        {
          "type": "window",
          "ops": [
            "row_number"
          ],
          "as": [
            "rank"
          ]
        },
        {
          "type": "filter",
          "expr": "datum.rank <= 10"
        },
        {
          "type": "formula",
          "as": "value",
          "expr": "datum.tonnes_2024"
        },
        {
          "type": "formula",
          "as": "displayValue",
          "expr": "format(datum.tonnes_2024, ',') + ' tonnes'"
        },
        {
          "type": "formula",
          "as": "tab",
          "expr": "'imports'"
        }
      ]
    },
    {
      "name": "exports_raw",
      "url": "https://raw.githubusercontent.com/TrucPhungLinh/fit2179new/refs/heads/main/coffee_global_exports.csv",
      "format": {
        "type": "csv",
        "parse": {
          "bags_2024": "number"
        }
      },
      "transform": [
        {
          "type": "collect",
          "sort": {
            "field": "bags_2024",
            "order": "descending"
          }
        },
        {
          "type": "window",
          "ops": [
            "row_number"
          ],
          "as": [
            "rank"
          ]
        },
        {
          "type": "filter",
          "expr": "datum.rank <= 10"
        },
        {
          "type": "formula",
          "as": "value",
          "expr": "datum.bags_2024"
        },
        {
          "type": "formula",
          "as": "displayValue",
          "expr": "format(datum.bags_2024, ',') + 'K bags'"
        },
        {
          "type": "formula",
          "as": "tab",
          "expr": "'exports'"
        }
      ]
    },
    {
      "name": "active_data",
      "source": [
        "imports_raw",
        "exports_raw"
      ],
      "transform": [
        {
          "type": "filter",
          "expr": "datum.tab === activeTab"
        },
        {
          "type": "collect",
          "sort": {
            "field": "value",
            "order": "descending"
          }
        },
        {
          "type": "window",
          "ops": [
            "row_number"
          ],
          "as": [
            "rank"
          ]
        },
        {
          "type": "joinaggregate",
          "ops": [
            "max"
          ],
          "fields": [
            "value"
          ],
          "as": [
            "maxVal"
          ]
        },
        {
          "type": "formula",
          "as": "arcRadius",
          "expr": "190 - (datum.rank - 1) * 13"
        },
        {
          "type": "formula",
          "as": "arcInner",
          "expr": "190 - (datum.rank - 1) * 13 - 5"
        },
        {
          "type": "formula",
          "as": "arcOuter",
          "expr": "190 - (datum.rank - 1) * 13 + 5"
        },
        {
          "type": "formula",
          "as": "arcEndAngle",
          "expr": "-PI/2 + (datum.value / datum.maxVal) * PI * 1.42"
        },
        {
          "type": "formula",
          "as": "listY",
          "expr": "315 + (datum.rank - 1) * 34"
        }
      ]
    }
  ],
  "marks": [
    {
      "type": "arc",
      "encode": {
        "enter": {
          "x": {
            "signal": "cx"
          },
          "y": {
            "signal": "cy"
          },
          "startAngle": {
            "value": -3.14159
          },
          "endAngle": {
            "value": 3.14159
          },
          "innerRadius": {
            "value": 255
          },
          "outerRadius": {
            "value": 292
          },
          "fill": {
            "value": "#D8C2A8"
          }
        }
      }
    },
    {
      "type": "arc",
      "encode": {
        "enter": {
          "x": {
