{
  "$schema": "https://vega.github.io/schema/vega/v5.json",
  "width": 1000,
  "height": 720,
  "padding": 20,
  "background": "#F7EFE4",
  "signals": [
    {
      "name": "activeTab",
      "value": "imports",
      "on": [
        {
          "events": {
            "type": "click",
            "markname": "tab_imports"
          },
          "update": "'imports'"
        },
        {
          "events": {
            "type": "click",
            "markname": "tab_imports_label"
          },
          "update": "'imports'"
        },
        {
          "events": {
            "type": "click",
            "markname": "tab_exports"
          },
          "update": "'exports'"
        },
        {
          "events": {
            "type": "click",
            "markname": "tab_exports_label"
          },
          "update": "'exports'"
        }
      ]
    },
    {
      "name": "cx",
      "value": 400
    },
    {
      "name": "cy",
      "value": 460
    }
  ],
  "data": [
    {
      "name": "imports_raw",
      "url": "https://raw.githubusercontent.com/TrucPhungLinh/fit2179new/refs/heads/main/coffee_australia_imports_tonnes.csv",
      "format": {
        "type": "csv",
        "parse": {
          "tonnes_2024": "number"
        }
      },
      "transform": [
        {
          "type": "filter",
          "expr": "datum.country !== 'Other'"
        },
        {
          "type": "collect",
          "sort": {
            "field": "tonnes_2024",
            "order": "descending"
          }
        },
        {
          "type": "window",
          "ops": [
            "row_number"
          ],
          "as": [
            "rank"
          ]
        },
        {
          "type": "filter",
          "expr": "datum.rank <= 10"
        },
        {
          "type": "formula",
          "as": "value",
          "expr": "datum.tonnes_2024"
        },
        {
          "type": "formula",
          "as": "displayValue",
          "expr": "format(datum.tonnes_2024, ',') + ' tonnes'"
        },
        {
          "type": "formula",
          "as": "tab",
          "expr": "'imports'"
        }
      ]
    },
    {
      "name": "exports_raw",
      "url": "https://raw.githubusercontent.com/TrucPhungLinh/fit2179new/refs/heads/main/coffee_global_exports_tonnes.csv",
      "format": {
        "type": "csv",
        "parse": {
          "tonnes_2024": "number"
        }
      },
      "transform": [
        {
          "type": "collect",
          "sort": {
            "field": "tonnes_2024",
            "order": "descending"
          }
        },
        {
          "type": "window",
          "ops": [
            "row_number"
          ],
          "as": [
            "rank"
          ]
        },
        {
          "type": "filter",
          "expr": "datum.rank <= 10"
        },
        {
          "type": "formula",
          "as": "value",
          "expr": "datum.tonnes_2024"
        },
        {
          "type": "formula",
          "as": "displayValue",
          "expr": "format(datum.tonnes_2024, ',') + ' tonnes'"
        },
        {
          "type": "formula",
          "as": "tab",
          "expr": "'exports'"
        }
      ]
    },
    {
      "name": "active_data",
      "source": [
        "imports_raw",
        "exports_raw"
      ],
      "transform": [
        {
          "type": "filter",
          "expr": "datum.tab === activeTab"
        },
        {
          "type": "collect",
          "sort": {
            "field": "value",
            "order": "descending"
          }
        },
        {
          "type": "window",
          "ops": [
            "row_number"
          ],
          "as": [
            "rank"
          ]
        },
        {
          "type": "joinaggregate",
          "ops": [
            "max"
          ],
          "fields": [
            "value"
          ],
          "as": [
            "maxVal"
          ]
        },
        {
          "type": "formula",
          "as": "arcInner",
          "expr": "170 - (datum.rank - 1) * 13 - 5"
        },
        {
          "type": "formula",
          "as": "arcOuter",
          "expr": "170 - (datum.rank - 1) * 13 + 5"
        },
        {
          "type": "formula",
          "as": "arcEndAngle",
          "expr": "-PI/2 + (datum.value / datum.maxVal) * PI * 1.48"
        },
        {
          "type": "formula",
          "as": "listY",
          "expr": "250 + (datum.rank - 1) * 28"
        }
      ]
    }
  ],
