{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "#F7EFE5",
  "width": 820,
  "height": 520,
  "padding": {
    "left": 25,
    "right": 35,
    "top": 25,
    "bottom": 20
  },
  "title": {
    "text": "☕ Coffee Intake and Health Risk Reduction",
    "subtitle": "Estimated % risk change by cups per day compared with non-drinkers · Use the dropdown to filter evidence strength",
    "fontSize": 25,
    "subtitleFontSize": 13,
    "color": "#2B160D",
    "subtitleColor": "#7A5132",
    "anchor": "start",
    "fontWeight": "bold",
    "offset": 18
  },
  "config": {
    "view": {
      "stroke": null
    },
    "font": "Arial",
    "axis": {
      "labelColor": "#4A2C1A",
      "titleColor": "#3B2415",
      "gridColor": "#E9D8C5",
      "domainColor": "#8B5E3C",
      "tickColor": "#8B5E3C",
      "labelFontSize": 12,
      "titleFontSize": 13,
      "titleFontWeight": "bold"
    },
    "legend": {
      "labelColor": "#4A2C1A",
      "titleColor": "#3B2415",
      "labelFontSize": 11,
      "titleFontSize": 12,
      "orient": "right",
      "padding": 10,
      "cornerRadius": 8,
      "fillColor": "#FFF8F0",
      "strokeColor": "#E5CBB0"
    },
    "title": {
      "color": "#3B2415",
      "subtitleColor": "#7A5132"
    }
  },
  "params": [
    {
      "name": "evidence_filter",
      "value": "All",
      "bind": {
        "input": "select",
        "options": [
          "All",
          "Strong",
          "Moderate",
          "Emerging"
        ],
        "name": "Evidence Level: "
      }
    }
  ],
  "data": {
    "url": "https://raw.githubusercontent.com/TrucPhungLinh/fit2179new/refs/heads/main/coffee_health_outcomes.csv",
    "format": {
      "type": "csv",
      "parse": {
        "cups_per_day": "number",
        "risk_change_pct": "number"
      }
    }
  },
  "transform": [
    {
      "filter": "evidence_filter === 'All' || datum.evidence_level === evidence_filter"
    },
    {
      "calculate": "datum.risk_change_pct < 0 ? 'Risk reduction' : 'Risk increase / no reduction'",
      "as": "risk_direction"
    },
    {
      "calculate": "datum.risk_change_pct + '%'",
      "as": "risk_label"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "rect",
        "color": "#E8C8A5",
        "opacity": 0.22,
        "cornerRadius": 12
      },
      "encoding": {
        "x": {
          "datum": 2
        },
        "x2": {
          "datum": 4
        },
        "y": {
          "datum": -50
        },
        "y2": {
          "datum": 6
        }
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "center",
        "baseline": "top",
        "fontSize": 11,
        "fontWeight": "bold",
        "color": "#7A5132"
      },
      "encoding": {
        "x": {
          "datum": 3
        },
        "y": {
          "datum": 5
        },
        "text": {
          "value": "moderate intake range"
        }
      }
    },
    {
      "mark": {
        "type": "rule",
        "strokeDash": [
          5,
          4
        ],
        "strokeWidth": 1.4,
        "color": "#8B5E3C",
        "opacity": 0.65
      },
      "encoding": {
        "y": {
          "datum": 0,
          "type": "quantitative"
        }
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "bottom",
        "fontSize": 11,
        "fontStyle": "italic",
        "color": "#7A5132",
        "dx": 4,
        "dy": -4
      },
      "encoding": {
        "x": {
          "datum": 0.85
        },
        "y": {
          "datum": 0
        },
        "text": {
          "value": "0% = no estimated change"
        }
      }
    },
    {
      "mark": {
        "type": "area",
        "opacity": 0.09,
        "interpolate": "monotone",
        "line": false
      },
      "encoding": {
        "x": {
          "field": "cups_per_day",
          "type": "quantitative"
        },
        "y": {
          "field": "risk_change_pct",
          "type": "quantitative"
        },
        "y2": {
          "datum": 0
        },
        "color": {
          "field": "condition",
          "type": "nominal",
          "scale": {
            "domain": [
              "Type 2 Diabetes",
              "Heart Disease",
              "Parkinson's Disease",
              "Liver Disease",
              "Depression",
              "Alzheimer's Disease"
            ],
            "range": [
              "#4A2314",
              "#7B3F1D",
              "#A86432",
              "#D19A57",
              "#8B5E3C",
              "#2B160D"
            ]
          },
          "legend": null
        }
      }
    },
    {
      "mark": {
        "type": "line",
        "strokeWidth": 3.5,
        "interpolate": "monotone"
      },
      "encoding": {
        "x": {
          "field": "cups_per_day",
          "type": "quantitative",
          "title": "Cups of Coffee Per Day",
          "scale": {
            "domain": [
              0.75,
              5.35
            ]
          },
          "axis": {
            "values": [
              1,
              2,
              3,
              4,
              5
            ],
            "labelExpr": "datum.value + ' cup' + (datum.value > 1 ? 's' : '')",
            "grid": false
          }
        },
        "y": {
          "field": "risk_change_pct",
          "type": "quantitative",
          "title": "Estimated Risk Change (%)",
          "scale": {
            "domain": [
              -50,
              6
            ]
          },
          "axis": {
            "format": "+d",
            "tickCount": 7
          }
        },
        "color": {
          "field": "condition",
          "type": "nominal",
          "title": "Health condition",
          "scale": {
            "domain": [
              "Type 2 Diabetes",
              "Heart Disease",
              "Parkinson's Disease",
              "Liver Disease",
              "Depression",
              "Alzheimer's Disease"
            ],
            "range": [
              "#4A2314",
              "#7B3F1D",
              "#A86432",
              "#D19A57",
              "#8B5E3C",
              "#2B160D"
            ]
          }
        },
        "strokeDash": {
          "field": "evidence_level",
          "type": "nominal",
          "title": "Evidence level",
          "scale": {
            "domain": [
              "Strong",
              "Moderate",
              "Emerging"
            ],
            "range": [
              [],
              [
                6,
                4
              ],
              [
                2,
                4
              ]
            ]
          }
        },
        "tooltip": [
          {
            "field": "condition",
            "type": "nominal",
            "title": "Condition"
          },
          {
            "field": "cups_per_day",
            "type": "quantitative",
            "title": "Cups per day"
          },
          {
            "field": "risk_change_pct",
            "type": "quantitative",
            "title": "Estimated risk change",
            "format": "+d"
          },
          {
            "field": "risk_direction",
            "type": "nominal",
            "title": "Meaning"
          },
          {
            "field": "evidence_level",
            "type": "nominal",
            "title": "Evidence level"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 95,
        "stroke": "#FDF6EE",
        "strokeWidth": 1.8
      },
      "encoding": {
        "x": {
          "field": "cups_per_day",
          "type": "quantitative"
        },
        "y": {
          "field": "risk_change_pct",
          "type": "quantitative"
        },
        "color": {
          "field": "condition",
          "type": "nominal",
          "scale": {
            "domain": [
              "Type 2 Diabetes",
              "Heart Disease",
              "Parkinson's Disease",
              "Liver Disease",
              "Depression",
              "Alzheimer's Disease"
            ],
            "range": [
              "#4A2314",
              "#7B3F1D",
              "#A86432",
              "#D19A57",
              "#8B5E3C",
              "#2B160D"
            ]
          },
          "legend": null
        },
        "tooltip": [
          {
            "field": "condition",
            "type": "nominal",
            "title": "Condition"
          },
          {
            "field": "cups_per_day",
            "type": "quantitative",
            "title": "Cups per day"
          },
          {
            "field": "risk_change_pct",
            "type": "quantitative",
            "title": "Estimated risk change",
            "format": "+d"
          },
          {
            "field": "evidence_level",
            "type": "nominal",
            "title": "Evidence level"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.cups_per_day === 5"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 9,
        "fontSize": 11,
        "fontWeight": "bold",
        "baseline": "middle"
      },
      "encoding": {
        "x": {
          "field": "cups_per_day",
          "type": "quantitative"
        },
        "y": {
          "field": "risk_change_pct",
          "type": "quantitative"
        },
        "text": {
          "field": "condition",
          "type": "nominal"
        },
        "color": {
          "field": "condition",
          "type": "nominal",
          "scale": {
            "domain": [
              "Type 2 Diabetes",
              "Heart Disease",
              "Parkinson's Disease",
              "Liver Disease",
              "Depression",
              "Alzheimer's Disease"
            ],
            "range": [
              "#4A2314",
              "#7B3F1D",
              "#A86432",
              "#D19A57",
              "#8B5E3C",
              "#2B160D"
            ]
          },
          "legend": null
        }
      }
    }
  ]
}