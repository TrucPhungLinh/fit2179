{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "#FFF8EF",
  "data": {
    "url": "https://raw.githubusercontent.com/TrucPhungLinh/fit2179new/refs/heads/main/australia_coffee_import_origins_2019_2024.csv"
  },
  "title": {
    "text": "Where does Australia import green coffee from?",
    "subtitle": "Import value (USD) in 2024",
    "anchor": "start",
    "fontSize": 22,
    "subtitleFontSize": 17,
    "color": "#4A2C1A",
    "subtitleColor": "#4a2d19"
  },
  "vconcat": [
    {
      "width": 920,
      "height": 470,
      "projection": {
        "type": "equalEarth",
        "rotate": [
          -150,
          0,
          0
        ]
      },
      "layer": [
        {
          "data": {
            "sphere": true
          },
          "mark": {
            "type": "geoshape",
            "fill": "#9CC4DB",
            "stroke": "#7EB0CB",
            "strokeWidth": 0.5
          }
        },
        {
          "data": {
            "graticule": {
              "step": [
                30,
                30
              ]
            }
          },
          "mark": {
            "type": "geoshape",
            "fill": null,
            "stroke": "#B8D6E8",
            "strokeWidth": 0.3
          }
        },
        {
          "data": {
            "url": "https://raw.githubusercontent.com/TrucPhungLinh/fit2179new/refs/heads/main/ne_50m_admin_0_countries%20(3).json",
            "format": {
              "type": "topojson",
              "feature": "ne_50m_admin_0_countries"
            }
          },
          "mark": {
            "type": "geoshape",
            "fill": "#C5CBA3",
            "stroke": "#FFFFFF",
            "strokeWidth": 0.6
          }
        },
        {
          "data": {
            "url": "https://raw.githubusercontent.com/TrucPhungLinh/fit2179new/refs/heads/main/ne_50m_admin_0_countries%20(3).json",
            "format": {
              "type": "topojson",
              "feature": "ne_50m_admin_0_countries"
            }
          },
          "transform": [
            {
              "lookup": "properties.NAME",
              "from": {
                "data": {
                  "url": "https://raw.githubusercontent.com/TrucPhungLinh/fit2179new/refs/heads/main/australia_coffee_import_origins_2019_2024.csv"
                },
                "key": "origin",
                "fields": [
                  "trade_value_musd",
                  "quantity_tonnes",
                  "unit_value_usd_per_kg",
                  "region",
                  "year"
                ]
              },
              "as": [
                "trade_value_musd",
                "quantity_tonnes",
                "unit_value_usd_per_kg",
                "region",
                "csv_year"
              ]
            },
            {
              "filter": "datum.csv_year == 2024"
            }
          ],
          "mark": {
            "type": "geoshape",
            "stroke": "#8B4513",
            "strokeWidth": 1.2
          },
          "encoding": {
            "color": {
              "field": "trade_value_musd",
              "type": "quantitative",
              "scale": {
                "type": "threshold",
                "domain": [
                  5,
                  15,
                  30,
                  60,
                  100
                ],
                "range": [
                  "#FFF3CD",
                  "#FFD166",
                  "#F4A261",
                  "#E76F51",
                  "#C1440E",
                  "#7B1D00"
                ]
              },
              "legend": {
                "title": "Import value (US$M)",
                "orient": "right",
                "direction": "vertical",
                "titleColor": "#4A2C1A",
                "labelColor": "#4A2C1A",
                "titleFontSize": 11,
                "labelFontSize": 10,
                "gradientLength": 150,
                "gradientThickness": 16,
                "values": [
                  5,
                  15,
                  30,
                  60,
                  100
                ],
                "fillColor": "#FFF8EF",
                "strokeColor": "#C8A870",
                "padding": 8,
                "cornerRadius": 5,
                "titlePadding": 6
              }
            },
            "tooltip": [
              {
                "field": "properties.NAME",
                "type": "nominal",
                "title": "Country"
              },
              {
                "field": "region",
                "type": "nominal",
                "title": "Region"
              },
              {
                "field": "trade_value_musd",
                "type": "quantitative",
                "title": "Import value (US$M)",
                "format": ".1f"
              },
              {
                "field": "quantity_tonnes",
                "type": "quantitative",
                "title": "Quantity (tonnes)",
                "format": ",.0f"
              },
              {
                "field": "unit_value_usd_per_kg",
                "type": "quantitative",
                "title": "Unit value (US$/kg)",
                "format": ".2f"
              }
            ]
          }
        },
        {
          "data": {
            "url": "https://raw.githubusercontent.com/TrucPhungLinh/fit2179new/refs/heads/main/australia_coffee_import_origins_2019_2024.csv"
          },
          "transform": [
            {
              "filter": "datum.year == 2024"
            },
            {
              "filter": "datum.origin == 'Brazil'"
            }
          ],
          "mark": {
            "type": "point",
            "filled": true,
            "size": 52,
            "color": "#FFF8EF",
            "stroke": "#4A2C1A",
            "strokeWidth": 1.2
          },
          "encoding": {
            "longitude": {
              "field": "longitude",
              "type": "quantitative"
            },
            "latitude": {
              "field": "latitude",
              "type": "quantitative"
            }
          }
        },
        {
          "data": {
            "url": "https://raw.githubusercontent.com/TrucPhungLinh/fit2179new/refs/heads/main/australia_coffee_import_origins_2019_2024.csv"
          },
          "transform": [
            {
              "filter": "datum.year == 2024"
            },
            {
              "filter": "datum.origin == 'Brazil'"
            },
            {
              "calculate": "'Brazil'",
              "as": "top_label"
            }
          ],
          "mark": {
            "type": "text",
            "fontSize": 14,
            "fontWeight": "bold",
            "align": "left",
            "dx": 88,
            "dy": -34,
            "color": "#3A2113",
            "font": "Arial",
            "stroke": "#FFF8EF",
            "strokeWidth": 3,
            "strokeOpacity": 0.9
          },
          "encoding": {
            "longitude": {
              "field": "longitude",
              "type": "quantitative"
            },
            "latitude": {
              "field": "latitude",
              "type": "quantitative"
            },
            "text": {
              "field": "top_label",
              "type": "nominal"
            }
          }
        },
        {
          "data": {
            "url": "https://raw.githubusercontent.com/TrucPhungLinh/fit2179new/refs/heads/main/australia_coffee_import_origins_2019_2024.csv"
          },
          "transform": [
            {
              "filter": "datum.year == 2024"
            },
            {
              "filter": "datum.origin == 'Brazil'"
            },
            {
              "calculate": "'US$127.7M'",
              "as": "top_label"
            }
          ],
          "mark": {
            "type": "text",
            "fontSize": 13,
            "fontWeight": "bold",
            "align": "left",
            "dx": 88,
            "dy": -18,
            "color": "#4A2C1A",
            "font": "Arial",
            "stroke": "#FFF8EF",
            "strokeWidth": 3,
            "strokeOpacity": 0.9
          },
          "encoding": {
            "longitude": {
              "field": "longitude",
              "type": "quantitative"
            },
            "latitude": {
              "field": "latitude",
              "type": "quantitative"
            },
            "text": {
              "field": "top_label",
              "type": "nominal"
            }
          }
        }
      ]
    },
    {
      "width": 900,
      "height": 110,
      "title": {
        "text": "Total green coffee import value over time",
        "anchor": "start",
        "color": "#4A2C1A"
      },
      "mark": {
        "type": "line",
        "point": {
          "filled": true,
          "size": 70
        },
        "color": "#7B3F00",
        "strokeWidth": 2.5
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "axis": {
            "title": "",
            "labelAngle": 0,
            "grid": false
          }
        },
        "y": {
          "aggregate": "sum",
          "field": "trade_value_musd",
          "type": "quantitative",
          "title": "US$M",
          "axis": {
            "tickCount": 4,
            "grid": false
          }
        },
        "tooltip": [
          {
            "field": "year",
            "type": "ordinal",
            "title": "Year"
          },
          {
            "aggregate": "sum",
            "field": "trade_value_musd",
            "type": "quantitative",
            "title": "Total import value (US$M)",
            "format": ".1f"
          }
        ]
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "font": "Arial",
    "title": {
      "font": "Arial",
      "fontSize": 14
    },
    "axis": {
      "labelColor": "#4A2C1A",
      "titleColor": "#4A2C1A",
      "labelFontSize": 13,
      "titleFontSize": 14
    },
    "legend": {
      "labelColor": "#4A2C1A",
      "titleColor": "#4A2C1A",
      "titleFontSize": 14,
      "labelFontSize": 13
    }
  }
}