{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "#FFF8EF",
  "width": 820,
  "height": 600,
  "title": {
    "text": "Melbourne Cafe & Restaurant Seating Capacity",
    "subtitle": "Explore seating capacity hotspots by year and seating type · Hover over points for details",
    "anchor": "start",
    "font": "Arial",
    "fontSize": 24,
    "fontWeight": "bold",
    "subtitleFontSize": 13,
    "color": "#2F1B12",
    "subtitleColor": "#7B5A45",
    "offset": 16
  },
  "projection": {
    "type": "mercator",
    "center": [144.9631, -37.8136],
    "scale": 300000
  },
  "params": [
    {
      "name": "melbourne_map_year_filter",
      "value": 2024,
      "bind": {
        "input": "range",
        "min": 2002,
        "max": 2024,
        "step": 1,
        "name": "Year: "
      }
    },
    {
      "name": "melbourne_map_seating_filter",
      "value": "All",
      "bind": {
        "input": "select",
        "options": ["All", "Seats - Indoor", "Seats - Outdoor", "Seats - Both"],
        "name": "Seating type: "
      }
    }
  ],
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/TrucPhungLinh/fit2179new/refs/heads/main/victoria.geojson",
        "format": {
          "type": "json"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#F1E4D2",
        "stroke": "#C8B49F",
        "strokeWidth": 0.8
      }
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/TrucPhungLinh/fit2179new/refs/heads/main/cafes-and-restaurants-with-seating-capacity.csv",
        "format": {
          "type": "csv"
        }
      },
      "transform": [
        {
          "filter": "datum.latitude != '' && datum.longitude != '' && datum.number_of_seats != ''"
        },
        {
          "calculate": "toNumber(datum.latitude)",
          "as": "lat"
        },
        {
          "calculate": "toNumber(datum.longitude)",
          "as": "lon"
        },
        {
          "calculate": "toNumber(datum.census_year)",
          "as": "year"
        },
        {
          "calculate": "toNumber(datum.number_of_seats)",
          "as": "seats"
        },
        {
          "filter": "datum.year == melbourne_map_year_filter"
        },
        {
          "filter": "melbourne_map_seating_filter == 'All' || datum.seating_type == melbourne_map_seating_filter"
        }
      ],
      "mark": {
        "type": "circle",
        "filled": true,
        "opacity": 0.72,
        "stroke": "#FFFFFF",
        "strokeWidth": 0.7
      },
      "encoding": {
        "longitude": {
          "field": "lon",
          "type": "quantitative"
        },
        "latitude": {
          "field": "lat",
          "type": "quantitative"
        },
        "size": {
          "field": "seats",
          "type": "quantitative",
          "scale": {
            "type": "sqrt",
            "domain": [0, 900],
            "range": [14, 520]
          },
          "legend": {
            "title": "Seats",
            "orient": "right",
            "labelFontSize": 11,
            "titleFontSize": 12
          }
        },
        "color": {
          "field": "seating_type",
          "type": "nominal",
          "title": "Seating Type",
          "scale": {
            "domain": ["Seats - Indoor", "Seats - Outdoor", "Seats - Both"],
            "range": ["#B45F3C", "#D99A3D", "#4E7A68"]
          },
          "legend": {
            "orient": "right",
            "labelFontSize": 11,
            "titleFontSize": 12
          }
        },
        "tooltip": [
          {
            "field": "trading_name",
            "type": "nominal",
            "title": "Business"
          },
          {
            "field": "seats",
            "type": "quantitative",
            "title": "Number of Seats"
          },
          {
            "field": "seating_type",
            "type": "nominal",
            "title": "Seating Type"
          },
          {
            "field": "clue_small_area",
            "type": "nominal",
            "title": "Area"
          },
          {
            "field": "year",
            "type": "ordinal",
            "title": "Year"
          }
        ]
      }
    },
    {
      "data": {
        "values": [{}]
      },
      "transform": [
        {
          "calculate": "'Year: ' + melbourne_map_year_filter",
          "as": "year_label"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "top",
        "x": 20,
        "y": 18,
        "font": "Arial",
        "fontSize": 34,
        "fontWeight": "bold",
        "color": "#3A2115"
      },
      "encoding": {
        "text": {
          "field": "year_label",
          "type": "nominal"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "note": "Larger circles represent venues with higher seating capacity. Use the slider and dropdown to compare how cafe and restaurant seating patterns change over time."
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "bottom",
        "x": 20,
        "y": 585,
        "font": "Arial",
        "fontSize": 12,
        "color": "#6F4D38",
        "limit": 650
      },
      "encoding": {
        "text": {
          "field": "note",
          "type": "nominal"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "legend": {
      "labelColor": "#3A2115",
      "titleColor": "#2F1B12",
      "symbolStrokeColor": "#FFFFFF"
    }
  }
}