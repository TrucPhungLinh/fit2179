{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "#FDFAF3",
  "width": 460,
  "height": 520,
  "padding": {
    "top": 8,
    "right": 16,
    "bottom": 16,
    "left": 16
  },
  "title": {
    "text": "GLOBAL COFFEE CONSUMPTION",
    "subtitle": "Bubble size = total volume (million 60kg bags).  Hover to explore.   Click to highlight",
    "fontSize": 18,
    "subtitleFontSize": 14.5,
    "color": "#2D1200",
    "subtitleColor": "#8B5530",
    "anchor": "middle",
    "fontWeight": "bold",
    "offset": 14
  },
  "config": {
    "view": {
      "stroke": null
    },
    "font": "Georgia",
    "axis": {
      "labelColor": "#5C2E00",
      "titleColor": "#5C2E00",
      "gridColor": "#9A7040",
      "gridOpacity": 0.35,
      "domainColor": "#C4956A",
      "tickColor": "#C4956A",
      "labelFontSize": 11,
      "titleFontSize": 14
    },
    "legend": {
      "labelColor": "#2D1200",
      "titleColor": "#5C2E00",
      "titleFontWeight": "bold",
      "labelFontSize": 13,
      "titleFontSize": 14,
      "fillColor": "#FDFAF3",
      "strokeColor": "#C4956A",
      "strokeWidth": 0.5,
      "padding": 10,
      "cornerRadius": 5
    }
  },
  "params": [
    {
      "name": "sort_by",
      "value": "kg_per_capita",
      "bind": {
        "input": "select",
        "options": [
          "kg_per_capita",
          "total_bags_million"
        ],
        "labels": [
          "Per Capita (kg/person)",
          "Total Volume (million bags)"
        ],
        "name": "Sort by: "
      }
    },
    {
      "name": "region_select",
      "value": "All",
      "bind": {
        "input": "select",
        "options": [
          "All",
          "Europe",
          "Oceania",
          "N. America",
          "S. America",
          "Asia"
        ],
        "name": "Region: "
      }
    }
  ],
  "data": {
    "url": "https://raw.githubusercontent.com/TrucPhungLinh/fit2179new/refs/heads/main/world_coffee_consumption.csv",
    "format": {
      "type": "csv",
      "parse": {
        "kg_per_capita": "number",
        "total_bags_million": "number",
        "cups_per_day": "number",
        "yoy_growth_pct": "number",
        "rank_per_capita": "number"
      }
    }
  },
  "transform": [
    {
      "filter": "region_select === 'All' || datum.region === region_select"
    },
    {
      "calculate": "sort_by === 'kg_per_capita' ? datum.kg_per_capita : datum.total_bags_million",
      "as": "sort_value"
    }
  ],
  "layer": [
    {
      "params": [
        {
          "name": "clicked",
          "select": {
            "type": "point",
            "on": "click"
          }
        }
      ],
      "mark": {
        "type": "circle",
        "cursor": "pointer"
      },
      "encoding": {
        "y": {
          "field": "country",
          "type": "nominal",
          "sort": {
            "field": "sort_value",
            "order": "descending"
          },
          "title": null,
          "axis": {
            "labelFontSize": 12,
            "labelColor": "#2D1200",
            "labelFont": "Georgia",
            "labelPadding": 22,
            "ticks": false,
            "domain": false
          }
        },
        "x": {
          "field": "sort_value",
          "type": "quantitative",
          "title": null,
          "scale": {
            "domainMin": -3,
            "nice": true
          },
          "axis": {
            "grid": true,
            "gridColor": "#9A7040",
            "gridOpacity": 0.35,
            "labelColor": "#8B5530",
            "labelFontSize": 10,
            "domain": false,
            "ticks": false,
            "tickCount": 5,
            "labelExpr": "datum.value < 0 ? '' : sort_by === 'kg_per_capita' ? format(datum.value, '.0f') + ' kg' : format(datum.value, '.0f') + ' M'",
            "labelPadding": 8
          }
        },
        "size": {
          "field": "total_bags_million",
          "type": "quantitative",
          "title": "Volume (M bags)",
          "scale": {
            "range": [
              50,
              2200
            ]
          },
          "legend": {
            "orient": "right",
            "direction": "vertical",
            "symbolStrokeColor": "#8B5530",
            "symbolStrokeWidth": 1.5
          }
        },
        "color": {
          "field": "region",
          "type": "nominal",
          "title": "Region",
          "scale": {
            "domain": [
              "Europe",
              "Oceania",
              "N. America",
              "S. America",
              "Asia"
            ],
            "range": [
              "#C05010",
              "#1E7A60",
              "#3A6898",
              "#A07210",
              "#8A3828"
            ]
          },
          "legend": {
            "orient": "right",
            "direction": "vertical",
            "symbolSize": 130,
            "symbolStrokeWidth": 0
          }
        },
        "stroke": {
          "condition": {
            "test": "datum.country === 'Australia'",
            "value": "#2D1200"
          },
          "value": "transparent"
        },
        "strokeWidth": {
          "condition": {
            "test": "datum.country === 'Australia'",
            "value": 2
          },
          "value": 0
        },
        "opacity": {
          "condition": {
            "param": "clicked",
            "empty": true,
            "value": 1
          },
          "value": 0.15
        },
        "tooltip": [
          {
            "field": "country",
            "type": "nominal",
            "title": "Country"
          },
          {
            "field": "region",
            "type": "nominal",
            "title": "Region"
          },
          {
            "field": "kg_per_capita",
            "type": "quantitative",
            "title": "kg / person / year",
            "format": ".1f"
          },
          {
            "field": "total_bags_million",
            "type": "quantitative",
            "title": "Total (M bags)",
            "format": ".2f"
          },
          {
            "field": "cups_per_day",
            "type": "quantitative",
            "title": "Cups / day / person",
            "format": ".2f"
          },
          {
            "field": "rank_per_capita",
            "type": "quantitative",
            "title": "Global Rank"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.country === 'Australia'"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 14,
        "fontSize": 11,
        "fontWeight": "bold",
        "font": "Georgia",
        "color": "#5C2E00"
      },
      "encoding": {
        "y": {
          "field": "country",
          "type": "nominal",
          "sort": {
            "field": "sort_value",
            "order": "descending"
          }
        },
        "x": {
          "field": "sort_value",
          "type": "quantitative"
        },
        "text": {
          "value": "\u2190 Australia"
        }
      }
    }
  ]
}