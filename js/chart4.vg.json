{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "#F8F0E3",
  "width": 650,
  "height": 360,
  "padding": { "left": 30, "right": 25, "top": 25, "bottom": 35 },
  "data": {
    "url": "https://raw.githubusercontent.com/TrucPhungLinh/fit2179new/refs/heads/main/coffee_health_benefit_bubble.csv"
  },
  "layer": [
    {
      "mark": { "type": "rect", "fill": "#FBF4E8", "stroke": "#E6D2B0", "strokeWidth": 1 }
    },
    {
      "mark": { "type": "rule", "stroke": "#E7D4B4", "strokeDash": [2, 4], "strokeWidth": 1 },
      "encoding": { "x": { "datum": 50 } }
    },
    {
      "mark": { "type": "rule", "stroke": "#E7D4B4", "strokeDash": [2, 4], "strokeWidth": 1 },
      "encoding": { "x": { "datum": 75 } }
    },
    {
      "mark": { "type": "rule", "stroke": "#E7D4B4", "strokeDash": [2, 4], "strokeWidth": 1 },
      "encoding": { "y": { "datum": 50 } }
    },
    {
      "mark": { "type": "rule", "stroke": "#E7D4B4", "strokeDash": [2, 4], "strokeWidth": 1 },
      "encoding": { "y": { "datum": 75 } }
    },
    {
      "data": {
        "values": [
          { "label": "BELIEF > EVIDENCE", "x": 12, "y": 96 },
          { "label": "BELIEF & EVIDENCE", "x": 75, "y": 96 },
          { "label": "UNDER-DISCUSSED",   "x": 12, "y": 5  },
          { "label": "EVIDENCE > BELIEF", "x": 75, "y": 5  }
        ]
      },
      "mark": {
        "type": "text",
        "font": "Poppins",
        "fontSize": 11,
        "fontWeight": 700,
        "color": "#9A7A55",
        "baseline": "middle"
      },
      "encoding": {
        "x": { "field": "x", "type": "quantitative" },
        "y": { "field": "y", "type": "quantitative" },
        "text": { "field": "label" }
      }
    },
    {
      "mark": { "type": "circle", "opacity": 0.72, "strokeWidth": 2 },
      "encoding": {
        "x": {
          "field": "evidence_score",
          "type": "quantitative",
          "scale": { "domain": [0, 100] },
          "axis": {
            "title": "Clinical evidence →",
            "titleFont": "Poppins",
            "titleFontSize": 13,
            "titleColor": "#6B4A2E",
            "labels": false, "ticks": false, "domain": true, "grid": false
          }
        },
        "y": {
          "field": "perception_score",
          "type": "quantitative",
          "scale": { "domain": [0, 100] },
          "axis": {
            "title": "Public perception →",
            "titleFont": "Poppins",
            "titleFontSize": 13,
            "titleColor": "#6B4A2E",
            "labels": false, "ticks": false, "domain": true, "grid": false
          }
        },
        "size": {
          "field": "share_drinkers",
          "type": "quantitative",
          "scale": { "range": [600, 4200] },
          "legend": null
        },
        "fill": {
          "field": "category",
          "type": "nominal",
          "scale": {
            "domain": ["Cognitive", "Emotional", "Lifestyle", "Physical"],
            "range": ["#F6A87D", "#F0B767", "#F4CC75", "#9DBE98"]
          },
          "legend": null
        },
        "stroke": {
          "field": "category",
          "type": "nominal",
          "scale": {
            "domain": ["Cognitive", "Emotional", "Lifestyle", "Physical"],
            "range": ["#D65F35", "#C77E2E", "#B98324", "#6E9A70"]
          },
          "legend": null
        },
        "tooltip": [
          { "field": "benefit",          "type": "nominal",      "title": "Benefit" },
          { "field": "evidence_score",   "type": "quantitative", "title": "Clinical evidence" },
          { "field": "perception_score", "type": "quantitative", "title": "Public perception" },
          { "field": "share_drinkers",   "type": "quantitative", "title": "% of drinkers" }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "font": "Poppins",
        "fontSize": 12,
        "fontWeight": 700,
        "color": "#2A1D14",
        "baseline": "middle",
        "dy": 1
      },
      "encoding": {
        "x": { "field": "evidence_score",   "type": "quantitative" },
        "y": { "field": "perception_score", "type": "quantitative" },
        "text": { "field": "benefit" },
        "tooltip": [
          { "field": "benefit",          "type": "nominal",      "title": "Benefit" },
          { "field": "evidence_score",   "type": "quantitative", "title": "Clinical evidence" },
          { "field": "perception_score", "type": "quantitative", "title": "Public perception" },
          { "field": "share_drinkers",   "type": "quantitative", "title": "% of drinkers" }
        ]
      }
    }
  ],
  "config": {
    "view": { "stroke": null },
    "axis": {
      "labelFont": "Poppins",
      "titleFont": "Poppins",
      "domainColor": "#D9BE96",
      "tickColor": "#D9BE96"
    }
  }
}